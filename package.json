{
  "name": "eat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "tailwindcss -i ./src/ui/tailwind.input.css -o ./src/ui/app.css",
    "build:worker-image": "docker build -t eat/worker-base:latest -f docker/worker-base/Dockerfile .",
    "start": "cd backend && go run ./cmd/eat",
    "start:go": "cd backend && go run ./cmd/eat",
    "start:node": "node src/server/index.js",
    "test": "node --test"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
