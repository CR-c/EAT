generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  ACTION_REQUIRED
  CANCELLED
  CLARIFYING
  COMPLETED
  DRAFT
  EXECUTING
  FAILED
  MERGING
  PLANNING
  PLAN_REVIEW
  REVIEWING
}

enum PlanSnapshotSource {
  APPROVED
  LEAD_GENERATED
  RESTORED_FROM_HISTORY
}

enum SubTaskStatus {
  BLOCKED
  PENDING
  READY
  RUNNING
  REVIEW_PENDING
  ACCEPTED
  DISCARD_PENDING
  REWORK_REQUIRED
  MERGED
  FAILED
  CANCELLED
  DISCARDED
}

enum MergeStatus {
  PENDING
  SUCCEEDED
  CONFLICT
  ABORTED
}

enum MergeOperation {
  MERGE
  REBASE
}

enum MailboxParticipantType {
  LEAD
  SUBTASK
  SYSTEM
}

enum MailboxTargetType {
  LEAD
  SUBTASK
}

enum MailboxMessageType {
  NOTE
  BLOCKER
  DELIVERABLE_READY
  API_CONTRACT
  DB_CONTRACT
  TEST_REQUEST
  REVIEW_REQUEST
}

model Project {
  id            String   @id
  name          String
  path          String   @unique
  defaultBranch String   @map("default_branch")
  createdAt     DateTime @map("created_at")
  updatedAt     DateTime @map("updated_at")
  tasks         Task[]

  @@map("projects")
}

model Task {
  id               String         @id
  projectId        String         @map("project_id")
  title            String
  description      String
  leadAgentType    String         @map("lead_agent_type")
  baseBranch       String         @map("base_branch")
  baseCommitSha    String         @map("base_commit_sha")
  status           TaskStatus     @default(DRAFT)
  planVersion      Int            @default(0) @map("plan_version")
  currentPlanJson  String?        @map("current_plan_json")
  approvedPlanJson String?        @map("approved_plan_json")
  lastError        String?        @map("last_error")
  createdAt        DateTime       @map("created_at")
  updatedAt        DateTime       @map("updated_at")
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mailboxMessages  MailboxMessage[]
  planSnapshots    PlanSnapshot[]
  subTasks         SubTask[]

  @@index([projectId, createdAt], map: "idx_tasks_project_id_created_at")
  @@map("tasks")
}

model PlanSnapshot {
  id        String             @id
  taskId    String             @map("task_id")
  version   Int
  source    PlanSnapshotSource
  payload   String
  createdAt DateTime           @map("created_at")
  task      Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt, id], map: "idx_plan_snapshots_task_id_created_at")
  @@map("plan_snapshots")
}

model SubTask {
  id                   String        @id
  taskId               String        @map("task_id")
  title                String
  description          String
  branchSuffix         String        @map("branch_suffix")
  dependencyBranchSuffixesJson String @default("[]") @map("dependency_branch_suffixes_json")
  branchName           String?       @map("branch_name")
  worktreePath         String?       @map("worktree_path")
  agentType            String        @map("agent_type")
  status               SubTaskStatus @default(PENDING)
  autoAssigned         Boolean       @default(true) @map("auto_assigned")
  retryCount           Int           @default(0) @map("retry_count")
  lastError            String?       @map("last_error")
  latestReviewDecision String?       @map("latest_review_decision")
  latestReviewPhase    String?       @map("latest_review_phase")
  latestReviewSummary  String?       @map("latest_review_summary")
  role                 String?
  displayName          String?       @map("display_name")
  executionOrder       Int?          @map("execution_order")
  assignmentSource     String?       @map("assignment_source")
  runSummary           String?       @map("run_summary")
  createdAt            DateTime      @map("created_at")
  updatedAt            DateTime      @map("updated_at")
  mergeRecords         MergeRecord[]
  sentMailboxMessages  MailboxMessage[] @relation("MailboxSenderSubTask")
  targetMailboxMessages MailboxMessage[] @relation("MailboxTargetSubTask")
  task                 Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt, id], map: "idx_sub_tasks_task_id_created_at")
  @@map("sub_tasks")
}

model MergeRecord {
  id              String         @id
  subTaskId       String         @map("sub_task_id")
  attemptNumber   Int            @map("attempt_number")
  operation       MergeOperation
  sourceBranch    String         @map("source_branch")
  targetBranch    String         @map("target_branch")
  status          MergeStatus
  resultCommitSha String?        @map("result_commit_sha")
  conflictSummary String?        @map("conflict_summary")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @map("created_at")
  updatedAt       DateTime       @map("updated_at")
  subTask         SubTask        @relation(fields: [subTaskId], references: [id], onDelete: Cascade)

  @@index([subTaskId, createdAt, id], map: "idx_merge_records_sub_task_id_created_at")
  @@map("merge_records")
}

model MailboxMessage {
  id              String                 @id
  taskId          String                 @map("task_id")
  senderType      MailboxParticipantType @map("sender_type")
  senderSubTaskId String?                @map("sender_sub_task_id")
  targetType      MailboxTargetType      @map("target_type")
  targetSubTaskId String?                @map("target_sub_task_id")
  messageType     MailboxMessageType     @default(NOTE) @map("message_type")
  artifactRefsJson String                @default("[]") @map("artifact_refs_json")
  fileRefsJson    String                 @default("[]") @map("file_refs_json")
  branchRef       String?                @map("branch_ref")
  schemaJson      String?                @map("schema_json")
  requiresAck     Boolean                @default(false) @map("requires_ack")
  content         String
  createdAt       DateTime               @map("created_at")
  senderSubTask   SubTask?               @relation("MailboxSenderSubTask", fields: [senderSubTaskId], references: [id], onDelete: Cascade)
  targetSubTask   SubTask?               @relation("MailboxTargetSubTask", fields: [targetSubTaskId], references: [id], onDelete: Cascade)
  task            Task                   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt, id], map: "idx_mailbox_messages_task_id_created_at")
  @@index([targetSubTaskId, createdAt, id], map: "idx_mailbox_messages_target_sub_task_id_created_at")
  @@map("mailbox_messages")
}
