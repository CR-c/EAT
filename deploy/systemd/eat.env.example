# Copy to /etc/eat/eat.env and adjust for your host.

HOST=127.0.0.1
PORT=3000

EAT_BACKEND_DB_PATH=/var/lib/eat/data/eat.db
EAT_UI_ROOT=/opt/eat/current/web/dist
EAT_MIGRATIONS_DIR=/opt/eat/current/prisma/migrations

EAT_UPLOAD_ROOT=/var/lib/eat/uploads
EAT_PREVIEW_ROOT=/var/lib/eat/preview-worktrees
EAT_WORKTREE_ROOT=/var/lib/eat/worktrees
EAT_CODEX_RUNTIME_ROOT=/var/lib/eat/codex-runtime

EAT_CODEX_AUTH_PATH=/var/lib/eat/home/.codex/auth.json
EAT_CODEX_CONFIG_PATH=/var/lib/eat/home/.codex/config.toml

EAT_WORKER_IMAGE=eat/worker-base:latest

